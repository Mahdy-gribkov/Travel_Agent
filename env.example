# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Firebase Admin (Server-side)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# Vector Database (Pinecone)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=travel-agent-embeddings

# Google OAuth (for NextAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# MCP Configuration
MCP_SERVER_URL=http://localhost:3001
MCP_AUTH_TOKEN=your_mcp_auth_token

# External APIs (Real Free APIs)
# Amadeus API - Free tier: 2000 calls/month
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret

# OpenWeatherMap API - Free tier: 1000 calls/day
OPENWEATHER_API_KEY=your_openweather_api_key

# Google Maps API - Free tier: $200 credit/month
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# REST Countries API - Completely free, no key needed
# No API key required for REST Countries API

# Security
# Optional API key for protecting endpoints (if not set, endpoints are open)
APP_API_KEY=your_optional_api_key_here

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=vaitravel-production

# Development
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Emulator (Development only)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost:5001

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_DEBUG_LOGGING=true
